<mvc:View
  controllerName="tictactoe.controller.Game"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:core="sap.ui.core">

  <Page title="Tic-Tac-Toe" showNavButton="true" navButtonPress=".onNavBack">
    <content>
      <VBox alignItems="Center" class="sapUiMediumMarginTop">

        <!-- Scoreboard -->
        <HBox justifyContent="Center" alignItems="Center" class="sapUiMediumMarginBottom">
          <VBox alignItems="Center" class="sapUiMediumMarginEnd">
            <Title text="Player X" />
            <Title text="{game>/player1Score}" level="H2" />
          </VBox>
          <VBox alignItems="Center" class="sapUiMediumMarginEnd">
            <Title text="vs" level="H4" />
          </VBox>
          <VBox alignItems="Center">
            <Title text="{game>/mode === 'HvB' ? 'Bot' : 'Player O'}" />
            <Title text="{game>/player2Score}" level="H2" />
          </VBox>
        </HBox>

        <!-- Current Player -->
        <MessageStrip
          text="Player {game>/currentPlayer}'s turn"
          type="Information"
          showIcon="true"
          showCloseButton="false"
          visible="{= ${game>/status} === 'active' }"
          class="sapUiMediumMarginBottom" />

        <!-- Winner Message -->
        <MessageStrip
          text="{game>/resultMessage}"
          type="Success"
          showIcon="true"
          showCloseButton="false"
            visible="{= ${game>/status} === 'finished' || ${game>/status} === 'roundOver' }"
          class="sapUiMediumMarginBottom" />

        <!-- Board -->
       <l:Grid
          defaultSpan="L4 M4 S4"
          class="sapUiMediumMarginBottom"
          width="300px">
          <l:content>
            <Button text="{game>/board/0}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="0" /></customData>
            </Button>
            <Button text="{game>/board/1}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="1" /></customData>
            </Button>
            <Button text="{game>/board/2}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="2" /></customData>
            </Button>
            <Button text="{game>/board/3}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="3" /></customData>
            </Button>
            <Button text="{game>/board/4}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="4" /></customData>
            </Button>
            <Button text="{game>/board/5}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="5" /></customData>
            </Button>
            <Button text="{game>/board/6}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="6" /></customData>
            </Button>
            <Button text="{game>/board/7}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="7" /></customData>
            </Button>
            <Button text="{game>/board/8}" press=".onCellPress" width="100px" type="Ghost"
            enabled="{= ${game>/status} === 'active' }">
              <customData><core:CustomData key="position" value="8" /></customData>
            </Button>
          </l:content>
        </l:Grid>
        <!-- Actions -->
        <HBox justifyContent="Center">
          <Button
            text="New Round"
            type="Emphasized"
            press=".onNewRound"
            visible="{= ${game>/status} === 'finished' || ${game>/status} === 'roundOver' }"
            class="sapUiSmallMarginEnd" />
          <Button
            text="Quit Game"
            type="Reject"
            press=".onNavBack" />
        </HBox>

      </VBox>
    </content>
  </Page>

</mvc:View>