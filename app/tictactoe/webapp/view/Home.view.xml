<mvc:View
  controllerName="tictactoe.controller.Home"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form">

  <Page title="Tic-Tac-Toe">
    <content>
      <VBox
        alignItems="Center"
        justifyContent="Center"
        class="sapUiMediumMarginTop">

        <!-- Game Mode -->
        <Title text="{i18n>gameMode}" class="sapUiSmallMarginBottom" />
        <SegmentedButton selectedKey="{game>/mode}" class="sapUiMediumMarginBottom">
          <items>
            <SegmentedButtonItem key="HvH" text="{i18n>humanVsHuman}" width="200px" />
            <SegmentedButtonItem key="HvB" text="{i18n>humanVsBot}" width="200px" />
          </items>
        </SegmentedButton>

        <!-- Difficulty -->
        <VBox visible="{= ${game>/mode} === 'HvB' }">
          <Title text="{i18n>difficulty}" class="sapUiSmallMarginBottom" />
          <SegmentedButton selectedKey="{game>/difficulty}" class="sapUiMediumMarginBottom">
            <items>
              <SegmentedButtonItem key="easy" text="{i18n>easy}" width="80px" />
              <SegmentedButtonItem key="medium" text="{i18n>medium}" width="80px" />
              <SegmentedButtonItem key="hard" text="{i18n>hard}" width="80px" />
            </items>
          </SegmentedButton>
        </VBox>

        <!-- Best of -->
        <Title text="{i18n>bestOf}" class="sapUiSmallMarginBottom" />
        <SegmentedButton selectedKey="{game>/totalMatches}" class="sapUiMediumMarginBottom">
          <items>
            <SegmentedButtonItem key="3" text="3" width="50px" />
            <SegmentedButtonItem key="5" text="5" width="50px" />
            <SegmentedButtonItem key="7" text="7" width="50px" />
          </items>
        </SegmentedButton>

        <!-- Start Button -->
        <Button
          text="{i18n>startGame}"
          type="Emphasized"
          press=".onStartGame" />

      </VBox>
    </content>
  </Page>

</mvc:View>