<mvc:View
  controllerName="tictactoe.controller.Home"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form">

  <Page title="Tic-Tac-Toe">
    <content>
      <VBox
        alignItems="Center"
        justifyContent="Center"
        class="sapUiMediumMarginTop">

        <!-- Game Mode -->
        <Title text="Game Mode" class="sapUiSmallMarginBottom" />
        <SegmentedButton selectedKey="{game>/mode}" class="sapUiMediumMarginBottom">
          <items>
            <SegmentedButtonItem key="HvH" text="Human vs Human" width="150px" />
            <SegmentedButtonItem key="HvB" text="Human vs Bot" width="150px" />
          </items>
        </SegmentedButton>

        <!-- Difficulty -->
        <VBox visible="{= ${game>/mode} === 'HvB' }">
          <Title text="Difficulty" class="sapUiSmallMarginBottom" />
          <SegmentedButton selectedKey="{game>/difficulty}" class="sapUiMediumMarginBottom">
            <items>
              <SegmentedButtonItem key="easy" text="Easy" width="80px" />
              <SegmentedButtonItem key="medium" text="Medium" width="80px" />
              <SegmentedButtonItem key="hard" text="Hard" width="80px" />
            </items>
          </SegmentedButton>
        </VBox>

        <!-- Best of -->
        <Title text="Best of" class="sapUiSmallMarginBottom" />
        <SegmentedButton selectedKey="{game>/totalMatches}" class="sapUiMediumMarginBottom">
          <items>
            <SegmentedButtonItem key="3" text="3" width="50px" />
            <SegmentedButtonItem key="5" text="5" width="50px" />
            <SegmentedButtonItem key="7" text="7" width="50px" />
          </items>
        </SegmentedButton>

        <!-- Start Button -->
        <Button
          text="Start Game"
          type="Emphasized"
          press=".onStartGame" />

      </VBox>
    </content>
  </Page>

</mvc:View>